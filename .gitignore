# Ignore ALL
*

# NOT ignore project files
!.gitignore
!README.md

# NOT ignore dotfiles in home path 
!.bashrc
!.tmux.conf

# NOT ignore .xmonad path
!.xmonad

# NOT ignore .config folder
!.config
!.config/*
