.config/gtk-2.0/gtkfilechooser.ini
.config/mimeapps.list
.config/nvim
.config/pavucontrol.ini

# NOT ignore SpaceVim customizations
!.SpaceVim.d
!.SpaceVim.d/*
.SpaceVim.d/.netrwhist

